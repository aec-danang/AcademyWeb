generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["elearning", "public"]
}

model Course {
  id          String             @id @default(cuid())
  title       String
  description String?
  price       Float              @default(0)
  imageUrl    String?
  published   Boolean            @default(false)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  program     String?
  curriculum  String?
  enrollments CourseEnrollment[]
  lessons     Lesson[]
  orders      Order[]
  classes     ClassSection[]

  @@schema("elearning")
}

model Lesson {
  id        String   @id @default(cuid())
  title     String
  content   String?
  videoUrl  String?
  order     Int      @default(0)
  published Boolean  @default(true)
  courseId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@schema("elearning")
}

model CourseEnrollment {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@schema("elearning")
}

model Post {
  title           String
  content         String
  slug            String   @id
  type            String   @default("post")
  published       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  authorId        String?
  excerpt         String?
  featuredImage   String?
  metaDescription String?
  metaTitle       String?
  author          User?    @relation(fields: [authorId], references: [id])

  @@schema("public")
}



model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  createdAt DateTime @default(now())
  message   String?
  status    String   @default("new")

  @@schema("public")
}

model Order {
  id          String   @id @default(cuid())
  userId      String?
  totalAmount Float
  status      String   @default("completed")
  createdAt   DateTime @default(now())
  courseId    String?
  course      Course?  @relation(fields: [courseId], references: [id])
  user        User?    @relation(fields: [userId], references: [id])

  @@schema("elearning")
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@schema("public")
}

model MenuItem {
  id        String  @id @default(cuid())
  label     String
  url       String
  order     Int     @default(0)
  position  String  @default("header")
  parentId  String?
  published Boolean @default(true)

  @@schema("public")
}

model Testimonial {
  id           String   @id @default(cuid())
  authorName   String
  authorRole   String?
  content      String
  avatarUrl    String?
  rating       Int      @default(5)
  published    Boolean  @default(true)
  order        Int      @default(0)
  score        String?
  isHallOfFame Boolean  @default(false)
  isFeatured   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  userId       String?
  user         User?    @relation(fields: [userId], references: [id])

  @@schema("public")
}

model Faq {
  id        String   @id @default(cuid())
  question  String
  answer    String
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@schema("public")
}

model Sponsor {
  id        String   @id @default(cuid())
  name      String
  imageUrl  String
  website   String?
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@schema("public")
}

model User {
  id            String             @id
  name          String?
  username      String?            @unique
  email         String?            @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role               @default(USER)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  courses       CourseEnrollment[]
  orders        Order[]
  Account       Account[]
  posts         Post[]
  Session       Session[]
  testimonials  Testimonial[]
  phone           String?
  isActive        Boolean          @default(true)
  activityLogs    ActivityLog[]
  attempts        Attempt[]        @relation("StudentAttempts")
  classSections   ClassSection[]   @relation("ClassTeacher")
  enrollments     Enrollment[]     @relation("StudentEnrollments")
  grades          Grade[]          @relation("StudentGrades")
  gradesGiven     Grade[]          @relation("GradesGiven")
  questions       Question[]       @relation("QuestionCreator")
  quizzes         Quiz[]           @relation("QuizCreator")
  submissions     Submission[]     @relation("StudentSubmissions")


  @@schema("elearning")
}

model Account {
  id                String  @id
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  User              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@schema("public")
}

model Session {
  id           String   @id
  sessionToken String   @unique
  userId       String
  expires      DateTime
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@schema("public")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@schema("public")
}

enum Role {
  USER
  TEACHER
  ADMIN
  STUDENT

  @@schema("elearning")
}
enum ClassStatus {
  ACTIVE
  ARCHIVED

  @@schema("elearning")
}

enum EnrollmentStatus {
  REQUESTED
  APPROVED
  REJECTED
  ACTIVE
  REMOVED

  @@schema("elearning")
}

enum AssignmentType {
  HOMEWORK
  WRITING
  SPEAKING
  FILE_UPLOAD

  @@schema("elearning")
}

enum AssignmentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED

  @@schema("elearning")
}

enum AssignmentDifficulty {
  EASY
  MEDIUM
  HARD

  @@schema("elearning")
}

enum SubmissionStatus {
  PENDING
  SUBMITTED
  GRADED
  MISSING

  @@schema("elearning")
}

enum QuestionType {
  MULTIPLE_CHOICE
  SHORT_ANSWER
  GRID
  FILL_BLANK
  ESSAY
  LISTENING
  READING

  @@schema("elearning")
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  AUTO_SUBMITTED
  GRADED

  @@schema("elearning")
}

enum ExamType {
  TOEIC
  IELTS
  GENERAL

  @@schema("elearning")
}

enum ExamSkill {
  LISTENING
  READING
  WRITING
  SPEAKING
  GRAMMAR
  MIXED

  @@schema("elearning")
}



model Program {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  band        String?
  description String?
  source      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  quizzes     Quiz[]

  @@schema("elearning")
}

model ClassSection {
  id          String       @id @default(cuid())
  name        String
  code        String       @unique
  status      ClassStatus  @default(ACTIVE)
  courseId    String
  teacherId   String?
  startAt     DateTime?
  endAt       DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  assignments Assignment[]
  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  enrollments Enrollment[]
  quizzes     Quiz[]
  teacher     User?        @relation("ClassTeacher", fields: [teacherId], references: [id], onDelete: SetNull)

  @@schema("elearning")
}

model Enrollment {
  id             String           @id @default(cuid())
  userId         String
  classSectionId String
  status         EnrollmentStatus @default(REQUESTED)
  requestedAt    DateTime         @default(now())
  decidedAt      DateTime?
  decidedById    String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  classSection   ClassSection     @relation(fields: [classSectionId], references: [id], onDelete: Cascade)
  student        User             @relation("StudentEnrollments", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, classSectionId])
  @@schema("elearning")
}

model Assignment {
  id             String               @id @default(cuid())
  title          String
  description    String?
  type           AssignmentType       @default(HOMEWORK)
  status         AssignmentStatus     @default(PUBLISHED)
  difficulty     AssignmentDifficulty @default(MEDIUM)
  category       String?
  tags           String[]             @default([])
  instructions   String?
  attachmentUrl  String?
  attachmentName String?
  dueAt          DateTime?
  classSectionId String
  createdById    String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  classSection   ClassSection         @relation(fields: [classSectionId], references: [id], onDelete: Cascade)
  grades         Grade[]
  submissions    Submission[]

  @@schema("elearning")
}

model QuestionBankCategory {
  id          String     @id @default(cuid())
  name        String     @unique
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  questions   Question[]

  @@schema("elearning")
}

model Question {
  id           String                @id @default(cuid())
  categoryId   String?
  createdById  String?
  type         QuestionType
  text         String
  section      String?
  sourceOrder  Int?
  sourceType   String?
  importSource String?
  audioUrl     String?
  passage      String?
  gridRows     Json?
  points       Float                 @default(1)
  answerKey    String?
  explanation  String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  answers      AttemptAnswer[]
  category     QuestionBankCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdBy    User?                 @relation("QuestionCreator", fields: [createdById], references: [id], onDelete: SetNull)
  options      QuestionOption[]
  quizLinks    QuizQuestion[]

  @@schema("elearning")
}

model QuestionOption {
  id         String          @id @default(cuid())
  questionId String
  label      String?
  text       String
  isCorrect  Boolean         @default(false)
  order      Int             @default(0)
  answers    AttemptAnswer[]
  question   Question        @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@schema("elearning")
}

model Quiz {
  id               String         @id @default(cuid())
  title            String
  description      String?
  classSectionId   String?
  createdById      String?
  programId        String?
  unit             String?
  sourceTitle      String?
  sourceGroup      String?
  importSource     String?
  isOpenQuiz       Boolean        @default(false)
  isPracticeTest   Boolean        @default(false)
  examType         ExamType       @default(GENERAL)
  skill            ExamSkill      @default(GRAMMAR)
  timeLimit        Int?
  instructions     String?
  audioUrl         String?
  passage          String?
  openAt           DateTime?
  closeAt          DateTime?
  attemptLimit     Int            @default(1)
  shuffleQuestions Boolean        @default(false)
  published        Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  attempts         Attempt[]
  classSection     ClassSection?   @relation(fields: [classSectionId], references: [id], onDelete: Cascade)
  createdBy        User?          @relation("QuizCreator", fields: [createdById], references: [id], onDelete: SetNull)
  grades           Grade[]
  program          Program?       @relation(fields: [programId], references: [id], onDelete: SetNull)
  questions        QuizQuestion[]
  sections         TestSection[]

  @@index([programId])
  @@index([importSource])
  @@schema("elearning")
}

model TestSection {
  id           String         @id @default(cuid())
  quizId       String
  title        String
  skill        ExamSkill      @default(READING)
  instructions String?
  audioUrl     String?
  passage      String?
  order        Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  questions    QuizQuestion[]
  quiz         Quiz           @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
  @@schema("elearning")
}

model QuizQuestion {
  id         String       @id @default(cuid())
  quizId     String
  sectionId  String?
  questionId String
  points     Float        @default(1)
  order      Int          @default(0)
  question   Question     @relation(fields: [questionId], references: [id], onDelete: Cascade)
  quiz       Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  section    TestSection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)

  @@unique([quizId, questionId])
  @@index([sectionId])
  @@schema("elearning")
}

model Attempt {
  id          String          @id @default(cuid())
  quizId      String
  studentId   String
  startedAt   DateTime        @default(now())
  submittedAt DateTime?
  status      AttemptStatus   @default(IN_PROGRESS)
  score       Float?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  answers     AttemptAnswer[]
  grades      Grade[]
  quiz        Quiz            @relation(fields: [quizId], references: [id], onDelete: Cascade)
  student     User            @relation("StudentAttempts", fields: [studentId], references: [id], onDelete: Cascade)

  @@schema("elearning")
}

model AttemptAnswer {
  id            String          @id @default(cuid())
  attemptId     String
  questionId    String
  optionId      String?
  answerText    String?
  isCorrect     Boolean?
  pointsAwarded Float?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  attempt       Attempt         @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  option        QuestionOption? @relation(fields: [optionId], references: [id], onDelete: SetNull)
  question      Question        @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
  @@schema("elearning")
}

model Submission {
  id           String           @id @default(cuid())
  assignmentId String
  studentId    String
  content      String?
  fileUrl      String?
  status       SubmissionStatus @default(SUBMITTED)
  submittedAt  DateTime         @default(now())
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  assignment   Assignment       @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  grade        Grade?
  student      User             @relation("StudentSubmissions", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, studentId])
  @@schema("elearning")
}

model Grade {
  id           String      @id @default(cuid())
  studentId    String
  assignmentId String?
  quizId       String?
  attemptId    String?
  submissionId String?     @unique
  score        Float
  feedback     String?
  gradedById   String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  assignment   Assignment? @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  attempt      Attempt?    @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  gradedBy     User?       @relation("GradesGiven", fields: [gradedById], references: [id], onDelete: SetNull)
  quiz         Quiz?       @relation(fields: [quizId], references: [id], onDelete: Cascade)
  student      User        @relation("StudentGrades", fields: [studentId], references: [id], onDelete: Cascade)
  submission   Submission? @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@schema("elearning")
}



model ActivityLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@schema("elearning")
}

model SiteProgram {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  content     String?
  iconType    String
  iconValue   String
  order       Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@schema("public")
}

model SiteFeature {
  id          String   @id @default(cuid())
  title       String
  description String
  iconValue   String
  order       Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@schema("public")
}
