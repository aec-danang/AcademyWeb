generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["elearning", "public"]
}

model Course {
  id          String             @id @default(cuid())
  title       String
  description String?
  price       Float              @default(0)
  imageUrl    String?
  published   Boolean            @default(false)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  enrollments CourseEnrollment[]
  lessons     Lesson[]
  orders      Order[]

  @@schema("elearning")
}

model Lesson {
  id        String   @id @default(cuid())
  title     String
  content   String?
  videoUrl  String?
  order     Int      @default(0)
  courseId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  tests     Test[]

  @@schema("elearning")
}

model CourseEnrollment {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@schema("elearning")
}

model Post {
  title           String
  content         String
  slug            String   @id
  type            String   @default("post")
  published       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  authorId        String?
  excerpt         String?
  featuredImage   String?
  metaDescription String?
  metaTitle       String?
  author          User?    @relation(fields: [authorId], references: [id])

  @@schema("public")
}

model Test {
  id        String         @id @default(cuid())
  title     String
  timeLimit Int?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  lessonId  String?
  lesson    Lesson?        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions TestQuestion[]
  results   TestResult[]

  @@schema("elearning")
}

model TestQuestion {
  id      String @id @default(cuid())
  testId  String
  text    String
  options String
  answer  String
  test    Test   @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@schema("elearning")
}

model TestResult {
  id        String   @id @default(cuid())
  testId    String
  userId    String?
  score     Float
  createdAt DateTime @default(now())
  test      Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id])

  @@schema("elearning")
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  createdAt DateTime @default(now())
  message   String?
  status    String   @default("new")

  @@schema("public")
}

model Order {
  id          String   @id @default(cuid())
  userId      String?
  totalAmount Float
  status      String   @default("completed")
  createdAt   DateTime @default(now())
  courseId    String?
  course      Course?  @relation(fields: [courseId], references: [id])
  user        User?    @relation(fields: [userId], references: [id])

  @@schema("elearning")
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@schema("public")
}

model MenuItem {
  id        String  @id @default(cuid())
  label     String
  url       String
  order     Int     @default(0)
  position  String  @default("header")
  parentId  String?
  published Boolean @default(true)

  @@schema("public")
}

model Testimonial {
  id         String   @id @default(cuid())
  authorName String
  authorRole String?
  content    String
  avatarUrl  String?
  rating     Int      @default(5)
  published  Boolean  @default(true)
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])

  @@schema("public")
}

model Faq {
  id        String   @id @default(cuid())
  question  String
  answer    String
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@schema("public")
}

model Sponsor {
  id        String   @id @default(cuid())
  name      String
  imageUrl  String
  website   String?
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@schema("public")
}

model User {
  id            String             @id
  name          String?
  email         String?            @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role               @default(USER)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime
  courses       CourseEnrollment[]
  orders        Order[]
  testResults   TestResult[]
  Account       Account[]
  posts         Post[]
  Session       Session[]
  testimonials  Testimonial[]

  @@schema("elearning")
}

model Account {
  id                String  @id
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  User              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@schema("public")
}

model Session {
  id           String   @id
  sessionToken String   @unique
  userId       String
  expires      DateTime
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@schema("public")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@schema("public")
}

enum Role {
  USER
  TEACHER
  ADMIN

  @@schema("elearning")
}
