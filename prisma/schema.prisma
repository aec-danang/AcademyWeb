generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["elearning", "public"]
}



// ---------------------------------------------
// E-LEARNING MODELS
// ---------------------------------------------

enum Role {
  USER
  TEACHER
  ADMIN

  @@schema("elearning")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(USER)

  // Merged Account fields
  provider          String?
  providerAccountId String?
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  // Merged Session fields
  sessionToken      String?   @unique
  sessionExpires    DateTime?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  courses      CourseEnrollment[]
  testResults  TestResult[]
  orders       Order[]
  posts        Post[]
  testimonials Testimonial[]

  @@unique([provider, providerAccountId])
  @@schema("elearning")
  @@map("users")
}

model Course {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  price       Float    @default(0)
  imageUrl    String?
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lessons     Lesson[]
  enrollments CourseEnrollment[]
  orders      Order[]

  @@schema("elearning")
}

model Lesson {
  id        String   @id @default(cuid())
  title     String
  content   String?  @db.Text
  videoUrl  String?
  order     Int      @default(0)
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tests     Test[]

  @@schema("elearning")
}



model CourseEnrollment {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, courseId])
  @@schema("elearning")
}

// ---------------------------------------------
// POSTS & PAGES (Blog/Tin tức)
// ---------------------------------------------

model Post {
  slug            String   @id
  title           String
  content         String   @db.Text
  excerpt         String?  @db.Text
  featuredImage   String?
  type            String   @default("post")
  published       Boolean  @default(true)
  metaTitle       String?
  metaDescription String?  @db.Text
  authorId        String?
  author          User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@schema("public")
}

// ---------------------------------------------
// QUIZ MASTER TESTS
// ---------------------------------------------

model Test {
  id        String         @id @default(cuid())
  title     String
  timeLimit Int?
  lessonId  String?
  lesson    Lesson?        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions TestQuestion[]
  results   TestResult[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@schema("elearning")
}

model TestQuestion {
  id      String @id @default(cuid())
  testId  String
  text    String @db.Text
  options String @db.Text
  answer  String
  test    Test   @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@schema("elearning")
}

model TestResult {
  id        String   @id @default(cuid())
  testId    String
  userId    String?
  score     Float
  createdAt DateTime @default(now())
  test      Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@schema("elearning")
}

// ---------------------------------------------
// KHÁCH HÀNG (Leads)
// ---------------------------------------------

model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  message   String?  @db.Text
  status    String   @default("new")
  createdAt DateTime @default(now())

  @@schema("public")
}

// ---------------------------------------------
// ĐƠN HÀNG (Orders)
// ---------------------------------------------

model Order {
  id          String   @id @default(cuid())
  userId      String?
  courseId    String?
  totalAmount Float
  status      String   @default("completed")
  createdAt   DateTime @default(now())
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  course      Course?  @relation(fields: [courseId], references: [id], onDelete: SetNull)

  @@schema("elearning")
}

// ---------------------------------------------
// SITE SETTINGS (CMS)
// ---------------------------------------------

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@schema("public")
}

// ---------------------------------------------
// NAVIGATION (CMS)
// ---------------------------------------------

model MenuItem {
  id        String  @id @default(cuid())
  label     String
  url       String
  order     Int     @default(0)
  position  String  @default("header") // e.g., "header", "footer"
  parentId  String?
  published Boolean @default(true)

  @@schema("public")
}

// ---------------------------------------------
// TESTIMONIALS (CMS)
// ---------------------------------------------

model Testimonial {
  id         String   @id @default(cuid())
  authorName String
  authorRole String?
  content    String   @db.Text
  avatarUrl  String?
  rating     Int      @default(5)
  published  Boolean  @default(true)
  order      Int      @default(0)
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@schema("public")
}

// ---------------------------------------------
// FAQS (CMS)
// ---------------------------------------------

model Faq {
  id        String   @id @default(cuid())
  question  String
  answer    String   @db.Text
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@schema("public")
}
